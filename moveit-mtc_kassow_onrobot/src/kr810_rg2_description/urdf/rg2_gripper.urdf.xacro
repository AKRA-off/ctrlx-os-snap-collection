<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="rg2_gripper">

  <!-- RG2 Gripper URDF Macro -->
  <!-- Based on OnRobot RG2 specifications -->
  <!-- Simplified model with single actuated joint and mimic joints for fingers -->

  <xacro:macro name="rg2_gripper" params="parent *origin prefix">

    <!-- Constants -->
    <xacro:property name="gripper_mass" value="1.685"/>
    <xacro:property name="finger_mass" value="0.05"/>

    <!-- Hand/Base Link -->
    <joint name="${prefix}gripper_base_joint" type="fixed">
      <xacro:insert_block name="origin"/>
      <parent link="${parent}"/>
      <child link="${prefix}rg2_hand"/>
    </joint>

    <link name="${prefix}rg2_hand">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${gripper_mass}"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0"
                 iyy="0.001" iyz="0.0"
                 izz="0.001"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://kr810_rg2_description/meshes/rg2-ft.stl"/>
        </geometry>
        <material name="grey">
          <color rgba="0.7 0.7 0.7 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://kr810_rg2_description/meshes/rg2-ft.stl"/>
        </geometry>
      </collision>
    </link>

    <!-- Left Finger Link -->
    <joint name="${prefix}left_finger_joint" type="prismatic">
      <parent link="${prefix}rg2_hand"/>
      <child link="${prefix}left_finger"/>
      <origin xyz="0.019 -0.009 0.04" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="0.0" upper="0.11" effort="10.6" velocity="0.15"/>
      <dynamics damping="0.1"/>
    </joint>

    <link name="${prefix}left_finger">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${finger_mass}"/>
        <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
                 iyy="0.0001" iyz="0.0"
                 izz="0.0001"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0.02" rpy="0 -1.5708 -1.5708"/>
        <geometry>
          <mesh filename="package://kr810_rg2_description/meshes/finger_neutral.stl"/>
        </geometry>
        <material name="black">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0.02" rpy="0 -1.5708 -1.5708"/>
        <geometry>
          <mesh filename="package://kr810_rg2_description/meshes/finger_neutral.stl"/>
        </geometry>
      </collision>
    </link>

    <!-- Right Finger Link (mimic left) -->
    <joint name="${prefix}right_finger_joint" type="prismatic">
      <parent link="${prefix}rg2_hand"/>
      <child link="${prefix}right_finger"/>
      <origin xyz="-0.019 -0.009 0.04" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="-0.11" upper="0.0" effort="10.6" velocity="0.15"/>
      <dynamics damping="0.1"/>
      <mimic joint="${prefix}left_finger_joint" multiplier="-1" offset="0"/>
    </joint>

    <link name="${prefix}right_finger">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${finger_mass}"/>
        <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
                 iyy="0.0001" iyz="0.0"
                 izz="0.0001"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0.02" rpy="0 -1.5708 1.5708"/>
        <geometry>
          <mesh filename="package://kr810_rg2_description/meshes/finger_neutral.stl"/>
        </geometry>
        <material name="black">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0.02" rpy="0 -1.5708 1.5708"/>
        <geometry>
          <mesh filename="package://kr810_rg2_description/meshes/finger_neutral.stl"/>
        </geometry>
      </collision>
    </link>

    <!-- Tool Center Point (TCP) -->
    <joint name="${prefix}tcp_joint" type="fixed">
      <parent link="${prefix}rg2_hand"/>
      <child link="${prefix}tcp"/>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}tcp"/>

  </xacro:macro>

</robot>
